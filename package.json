{
  "name": "peercert",
  "version": "0.1.1",
  "description": "Peer-to-peer certificate issuance and management.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "bsv",
    "bitcoin",
    "certificate",
    "peer-to-peer",
    "identity",
    "attestation",
    "credentials",
    "blockchain"
  ],
  "author": "Peer-to-peer Privacy Systems Research, LLC",
  "license": "Proprietary",
  "dependencies": {
    "@bsv/did-client": "^1.1.0",
    "@bsv/message-box-client": "^1.4.5",
    "@bsv/sdk": "^1.9.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.txt"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/p2ppsr/peercert.git"
  }
}
